# --- Database ---
# dev (sqlite):
DATABASE_URL=sqlite+aiosqlite:///./spotizer.db
# production (postgres):
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/spotizer

# --- Client API keys (OPTIONAL) ---
# Leave empty to DISABLE auth completely (open API).
# To enable: format is platform:key, comma separated. Each client sends its key
# in the X-Client-Key header (or ?key=... query param).
CLIENT_KEYS=
# CLIENT_KEYS=android:change-me-android-key,telegram:change-me-telegram-key

# --- Downloads ---
TEMP_DIR=/tmp/spotizer
FILE_TTL_MINUTES=30
MAX_CONCURRENT_DOWNLOADS=2
DEEZER_ARL=your_deezer_arl_cookie_here

# --- Track library (stream + direct download for the Android app) ---
# permanent storage: tracks stay here so they are never downloaded twice
MUSIC_DIR=./music
# how long /tracks/{id}/stream|download waits for an on-demand download (seconds)
ON_DEMAND_TIMEOUT_SECONDS=120

# --- Recommendations (/recommend in the bot) ---
# Google Gemini API key. Leave empty to disable LLM recommendations.
GEMINI_API_KEY=

DEBUG=false
