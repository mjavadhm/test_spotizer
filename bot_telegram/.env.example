BOT_TOKEN=123456:your-telegram-bot-token

# Spotizer API
API_BASE_URL=http://localhost:8000
# only needed if CLIENT_KEYS is set on the API (use the telegram key)
CLIENT_KEY=

# optional: local Telegram Bot API server for files > 50MB
# TELEGRAM_API_SERVER=http://localhost:8081

# platform name this bot registers users under.
# Must match the platform of CLIENT_KEY in the API's CLIENT_KEYS
# ("default" when CLIENT_KEYS is empty / auth disabled).
PLATFORM_NAME=default

# how often to check followed artists for new releases (seconds)
SUB_CHECK_INTERVAL_SECONDS=3600

# where the bot stores forum-topic ids (JSON file)
TOPICS_FILE=topics.json
